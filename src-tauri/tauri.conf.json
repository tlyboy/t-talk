{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "T-Talk",
  "version": "0.1.0",
  "identifier": "com.tlyboy.t-talk",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "T-Talk",
        "width": 980,
        "height": 710
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tlyboy/t-talk/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg3RjFBRkQyODQ5MzI1MjMKUldRakpaT0UwcS94aHlmaFlWS21PWHliL1l6R3RacFgwbmFjcWJ5ZHF1MWpjZ1pHbWtJcUVlRnEK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": ["English", "SimpChinese"],
        "displayLanguageSelector": true
      }
    }
  }
}
